# Treat Unreal Engine content assets as binary so Git does not attempt text diff or CRLF conversion
*.uasset -text diff
*.umap -text diff
*.ubulk -text
*.uexp -text
*.uptnl -text
*.umap* -text diff

# Keep project and plugin metadata as text
*.uproject text
*.uplugin text
*.ini text
*.cpp text
*.h text
*.cs text
*.json text
*.xml text
*.txt text
